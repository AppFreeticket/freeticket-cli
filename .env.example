# Endpoint de la API B2B (sin /api/v1 — el CLI lo agrega).
FT_API_URL=https://admin.appfreeticket.com

# API key de larga vida. Se emite en el backend con: pnpm api:key <email>
FT_API_KEY=ft_live_xxxxxxxxxxxxx

# Workspace (organización) activo por defecto. Opcional: si se omite, se usa el "home".
FT_WORKSPACE_ID=
